<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- Security: Block access to sensitive files ---
  RewriteRule ^\.git/ - [F,L]
  RewriteRule ^\.env - [F,L]
  RewriteRule ^data/ - [F,L]
  RewriteRule ^.*\.log$ - [F,L]

  # --- Clean URLs: Remove .php extension ---
  # Redirect external requests for .php files to clean URLs (301 permanent)
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
  RewriteRule ^ %1 [R=301,L]

  # --- Clean URLs: Internally rewrite clean URLs to .php files ---
  # If the request is not a file or directory, try adding .php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([^/]+)/?$ $1.php [L,QSA]

  # --- Service pages: /service/slug → /service/index.php?slug=slug ---
  RewriteRule ^service/([a-z0-9-]+)/?$ service/index.php?slug=$1 [L,QSA]

  # --- Blog post: /blog/slug → /blog-post.php?slug=slug ---
  RewriteRule ^blog/([a-z0-9-]+)/?$ blog-post.php?slug=$1 [L,QSA]
</IfModule>

# -----------------------------
# Compression: Brotli (preferred) + Gzip fallback
# -----------------------------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml font/woff2 font/woff
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

# -----------------------------
# Security Headers
# -----------------------------
<IfModule mod_headers.c>
  # Protect against clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  # XSS Protection
  Header always set X-XSS-Protection "1; mode=block"
  # MIME sniffing protection
  Header always set X-Content-Type-Options "nosniff"
  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# -----------------------------
# Browser caching
# -----------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"
  ExpiresByType application/json "access plus 1 day"

  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/webp "access plus 60 days"
  ExpiresByType image/avif "access plus 60 days"
  ExpiresByType image/png "access plus 60 days"
  ExpiresByType image/jpeg "access plus 60 days"
  ExpiresByType image/gif "access plus 60 days"
  ExpiresByType image/x-icon "access plus 60 days"

  ExpiresByType font/woff2 "access plus 90 days"
  ExpiresByType font/woff "access plus 90 days"
  ExpiresByType application/font-woff2 "access plus 90 days"
  ExpiresByType application/font-woff "access plus 90 days"

  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType video/webm "access plus 30 days"

  ExpiresDefault "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|mjs|jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf|eot|mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  <FilesMatch "\.(html|htm|php)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
